# ============================================================
# REQUIRED — App will not start without these
# ============================================================

# Supabase (https://app.supabase.com → Project Settings → API)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Session security — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32-char-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# OPTIONAL — Features degrade gracefully without these
# ============================================================

# AI Tutor (Dr. Nexus) — at least one required for AI features
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Video transcoding — choose one:
# Option A: Mux (https://mux.com)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Option B: AWS MediaConvert
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_MEDIA_CONVERT_ENDPOINT=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
